PORT=3000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# mysql or postgres. The matching driver is already in package.json.
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=habitup
DB_USER=root
DB_PASSWORD=
DB_LOGGING=false

# Optional alternative for hosted databases.
# DATABASE_URL=postgres://user:password@host:5432/habitup

# Development convenience only. This lets Sequelize update tables while iterating.
DB_SYNC_ALTER=true

# Used once by POST /setup/admin to create the first admin account.
BOOTSTRAP_ADMIN_KEY=replace-this-bootstrap-key
